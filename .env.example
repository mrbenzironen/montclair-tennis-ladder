# Copy this to .env.local and fill in your values
# Get these from your Supabase project: Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: override public URL (defaults to https://montclair-tennis-ladder.vercel.app). Use for Vercel preview URLs or localhost.
# VITE_PUBLIC_APP_URL=https://montclair-tennis-ladder.vercel.app

# Google reCAPTCHA v2 (“I’m not a robot” checkbox). Create keys at https://www.google.com/recaptcha/admin
# Use reCAPTCHA v2 → “I’m not a robot” Checkbox. Add your site domains (and localhost for dev).
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Edge Function email-captcha-auth: set RECAPTCHA_SECRET_KEY in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# (same key pair as above; this is the secret key, never put it in Vite env)
